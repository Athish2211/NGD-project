{
  "name": "dynamic-pricing-ecommerce",
  "version": "1.0.0",
  "description": "Dynamic pricing e-commerce platform with real-time demand-based pricing",
  "main": "server/index.js",
  "scripts": {
    "dev": "node scripts/dev-safe.js",
    "dev:raw": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "install-deps": "npm install && cd server && npm install && cd ../client && npm install",
    "setup-db": "cd server && npm run setup-db"
  },
  "keywords": ["ecommerce", "dynamic-pricing", "react", "nodejs", "postgresql", "redis"],
  "author": "Dynamic Pricing Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
